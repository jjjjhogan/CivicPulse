# Copy to .env and adjust for local development.
# .env is gitignored — never commit real secrets.

FLASK_SECRET_KEY=civicpulse-dev-only-change-me
HOST=127.0.0.1
PORT=8080
# SQLite by default (created under data/ on first run)
DATABASE_URL=sqlite:///data/civicpulse.db
# Optional — defaults to sqlite:///…/data/civicpulse.db
# DATABASE_URL=sqlite:///C:/path/to/data/civicpulse.db
# Optional TikTok Chrome profile (default: data/chrome/tiktok_profile)
# CIVICPULSE_CHROME_PROFILE=C:/path/to/chrome/profile
